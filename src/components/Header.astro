---
import { ModeToggle } from "@/components/mode-toggle";
import { ContactDialog } from "@/components/ContactDialog";
import { NAME } from "@/config";
import { url } from "@/lib/url";

const { activeId } = Astro.props;

const navItems = [
  { id: "home", label: "Home", href: url("/") },
  { id: "works", label: "Works", href: url("/works") },
  { id: "articles", label: "Articles", href: url("/articles") },
];
---

<header class="sticky top-0 z-40 w-full border-b border-border/80 bg-background/70 backdrop-blur">
  <div class="mx-auto flex h-16 max-w-4xl items-center justify-between px-6">
    <a
      href={url("/")}
      class="text-sm font-semibold tracking-tight transition-opacity hover:opacity-70"
    >
      <!-- {NAME} -->
    </a>
    <nav class="flex items-center gap-5 text-sm sm:gap-6">
      {
        navItems.map((item) => (
          <a
            href={item.href}
            class:list={[
              "transition-colors hover:text-foreground",
              activeId === item.id ? "text-foreground" : "text-muted-foreground",
            ]}
          >
            {item.label}
          </a>
        ))
      }
      <ContactDialog client:load variant="text" label="Contact" />
      <span class="ml-0.5">
        <ModeToggle client:load />
      </span>
    </nav>
  </div>
</header>
